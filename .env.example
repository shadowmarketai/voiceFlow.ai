# ============================================
# VoiceFlow AI SaaS — Environment Variables
# ============================================
# Copy to .env and fill in your values

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://voiceflow:voiceflow_secret@localhost:5432/voiceflow
DB_PASSWORD=voiceflow_secret
REDIS_URL=redis://localhost:6379/0

# ── Auth ─────────────────────────────────────
SECRET_KEY=generate-with-python-secrets-token-urlsafe-32

# ── LLM Providers ────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Telephony (India-first) ──────────────────
# TeleCMI (Primary — cheapest for India)
TELECMI_API_KEY=
TELECMI_API_SECRET=
TELECMI_ACCOUNT_ID=

# Bolna (AI voice agents)
BOLNA_API_KEY=

# Vobiz (Bulk voice + IVR)
VOBIZ_API_KEY=
VOBIZ_SENDER_ID=
VOBIZ_API_SECRET=

# Exotel (IVR focused)
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=

# Twilio (International)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Vonage (International)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_APPLICATION_ID=
VONAGE_PRIVATE_KEY_PATH=

# SIP Trunk
SIP_HOST=
SIP_PORT=5060
SIP_USERNAME=
SIP_PASSWORD=
SIP_TRANSPORT=udp

# WebRTC (auto-configured, no external keys needed)
WEBRTC_ENABLED=true
WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302

# ── Payments (India) ────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Monitoring ───────────────────────────────
SENTRY_DSN=

# ── Voice AI ─────────────────────────────────
WHISPER_MODEL=base
TORCH_DEVICE=cpu
SARVAM_API_KEY=
DEEPGRAM_API_KEY=

# ── WhatsApp ─────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
